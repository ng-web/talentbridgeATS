# Root-level .env for Docker Compose variable substitution.
# Copy to .env alongside docker-compose.prod.yml on the server.
# This is separate from src/.env (which holds all Laravel config).
# The DB values here must match DB_* values in src/.env.

DB_DATABASE=kairox_portal
DB_USERNAME=kairox
DB_PASSWORD=changeme_strong_password
MYSQL_ROOT_PASSWORD=changeme_root_password
